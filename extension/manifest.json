{
  "key": "",
  "manifest_version": 3,
  "name": "ChromeChain",
  "version": "2.0.0",
  "description": "AURA 语音助手浏览器注入器",
  "permissions": ["tabs", "scripting", "alarms", "storage"],
  "host_permissions": [
    "*://chat.deepseek.com/*",
    "*://kimi.moonshot.cn/*",
    "*://www.doubao.com/*",
    "*://chatgpt.com/*",
    "*://chat.openai.com/*",
    "*://tongyi.aliyun.com/*",
    "ws://127.0.0.1/*",
    "ws://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": [
      "*://chat.deepseek.com/*",
      "*://kimi.moonshot.cn/*",
      "*://www.doubao.com/*",
      "*://chatgpt.com/*",
      "*://chat.openai.com/*",
      "*://tongyi.aliyun.com/*"
    ],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}
